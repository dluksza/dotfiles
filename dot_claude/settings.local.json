{
  "env": {
    "USE_BUILTIN_RIPGREP": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(~/.claude-code-docs/claude-docs-helper.sh:*)",
      "WebSearch",
      "Skill(datetime)",
      "Bash(/Users/lock/.claude/skills/datetime/scripts/get_date.sh:*)",
      "Skill(macos-notifications)",
      "Bash(bash:*)",
      "Bash(/Users/lock/.claude/skills/macos-notifications/scripts/notify.sh:*)",
      "Skill(x-followers-skill)",
      "Bash(python:*)",
      "Bash(python3:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v osascript >/dev/null 2>&1; then osascript -e 'display notification \"Tool: $CLAUDE_TOOL_NAME completed\" with title \"Claude Code\"'; elif command -v notify-send >/dev/null 2>&1; then notify-send 'Claude Code' \"Tool: $CLAUDE_TOOL_NAME completed\"; fi"
          }
        ]
      }
    ]
  }
}
