{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(uv:*)",
      "Bash(find:*)",
      "Bash(mv:*)",
      "Bash(grep:*)",
      "Bash(npm:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Write",
      "Bash(chmod:*)",
      "Bash(touch:*)",
      "Bash(flutter:*)",
      "Bash(mix:*)",
      "Bash(devenv:*)",
      "Bash(bun:*)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Read(./build)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./config/credentials.*)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(./.npmrc)",
      "Read(~/.npmrc)",
      "Read(~/.ssh/**)",
      "Read(./.ssh/**)",
      "Read(./private/**)",
      "Write(./.env*)",
      "Write(./.ssh/**)",
      "Write(~/.ssh/**)",
      "Write(./config/credentials.*)",
      "Write(./secrets/**)",
      "NotebookEdit"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "agent-skills@addy-agent-skills": true,
    "figma@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "callstack-agent-skills": {
      "source": {
        "source": "github",
        "repo": "callstackincubator/agent-skills"
      }
    },
    "addy-agent-skills": {
      "source": {
        "source": "github",
        "repo": "addyosmani/agent-skills"
      }
    }
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
