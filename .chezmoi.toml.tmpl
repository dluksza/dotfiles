{{- $email := promptStringOnce . "email" "Email address" -}}
{{- /* Profile: seeded non-interactively by bootstrap via CHEZMOI_PROFILE;
       falls back to an interactive choice. Once written to [data] below,
       later `chezmoi apply` runs reuse it without prompting. */ -}}
{{- $profile := env "CHEZMOI_PROFILE" -}}
{{- if not $profile -}}
{{-   $profile = promptChoiceOnce . "profile" "Profile" (list "personal" "work") "personal" -}}
{{- end -}}

encryption = "age"
[age]
  identity = "~/.config/chezmoi/key.txt"
  recipient = "age1ktnkc8hha6fru7ylar7fa3x2wzjuk2mplnjykwkqur8v6ekh8d9q4kkydv"

[data]
  email = {{ $email | quote }}
  profile = {{ $profile | quote }}

[[textcov]]
  pattern = "**/*.plist"
  command = "plutil"
  args = ["-convert", "xml1", "-o", "-"]
